<mxfile host="Electron" version="21.6.8" type="device"><diagram id="LineTracerArch" name="Architecture"><mxGraphModel dx="1000" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" background="#F5F7FA"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="P_bg" value="1. 인지 (Perception)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;spacingTop=20;fontSize=24;fontStyle=1;fontColor=#2D3748;shadow=1;opacity=90;fillColor=#EBF8FF;strokeColor=#63B3ED;" parent="1" vertex="1"><mxGeometry x="50" y="50" width="360" height="950" as="geometry" /></mxCell><mxCell id="D_bg" value="2. 판단 (Decision)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;spacingTop=20;fontSize=24;fontStyle=1;fontColor=#2D3748;shadow=1;opacity=90;fillColor=#FFFFF0;strokeColor=#F6E05E;" parent="1" vertex="1"><mxGeometry x="450" y="50" width="360" height="950" as="geometry" /></mxCell><mxCell id="C_bg" value="3. 제어 (Control)" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;spacingTop=20;fontSize=24;fontStyle=1;fontColor=#2D3748;shadow=1;opacity=90;fillColor=#FFF5F5;strokeColor=#FC8181;" parent="1" vertex="1"><mxGeometry x="850" y="50" width="360" height="950" as="geometry" /></mxCell><mxCell id="p1" value="1. 이미지 획득 및 시작&#10;(image_callback)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="120" width="300" height="70" as="geometry" /></mxCell><mxCell id="p2" value="2. 파라미터 런타임 갱신&#10;(k, base_vel)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="220" width="300" height="70" as="geometry" /></mxCell><mxCell id="p3" value="3. JPEG 디코딩&#10;(cv::imdecode)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="320" width="300" height="70" as="geometry" /></mxCell><mxCell id="p4" value="4. ROI 추출&#10;(하단 1/4 깊은 복사)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="420" width="300" height="70" as="geometry" /></mxCell><mxCell id="p5" value="5. 그레이스케일 변환&#10;(BGR → GRAY)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="520" width="300" height="70" as="geometry" /></mxCell><mxCell id="p6" value="6. 밝기 정규화&#10;(조명 변화 대응)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="620" width="300" height="70" as="geometry" /></mxCell><mxCell id="p7" value="7. 이진화&#10;(Threshold &gt; 150)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="720" width="300" height="70" as="geometry" /></mxCell><mxCell id="p8" value="8. Connected Component 분석&#10;(객체 라벨링 및 스탯 획득)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="80" y="820" width="300" height="70" as="geometry" /></mxCell><mxCell id="d1" value="1. 후보 blob 필터링&#10;(면적 &gt; 100px)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="480" y="120" width="300" height="70" as="geometry" /></mxCell><mxCell id="d2" value="2. 1단계 최근접 탐색&#10;(이전 추적점 기준 거리 &lt; 150)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="480" y="220" width="300" height="70" as="geometry" /></mxCell><mxCell id="d3" value="3. 추적점 1차 갱신" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="480" y="320" width="300" height="70" as="geometry" /></mxCell><mxCell id="d4" value="4. 2단계 재탐색&#10;(면적 무관, 새 추적점 기준)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="480" y="420" width="300" height="70" as="geometry" /></mxCell><mxCell id="d5" value="5. 최종 최소거리&#10;&lt;= 30px ?" style="rhombus;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="480" y="520" width="300" height="100" as="geometry" /></mxCell><mxCell id="d6y" value="라인 유효 검출&#10;(best_idx 확정)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;fillColor=#C6F6D5;strokeColor=#38A169;" parent="1" vertex="1"><mxGeometry x="480" y="680" width="140" height="70" as="geometry" /></mxCell><mxCell id="d6n" value="라인 손실 판단&#10;(last_line 유지)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;fillColor=#FED7D7;strokeColor=#E53E3E;" parent="1" vertex="1"><mxGeometry x="640" y="680" width="140" height="70" as="geometry" /></mxCell><mxCell id="d7" value="6. 오차(Error) 계산&#10;(가운데 X - 현재 라인 X)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="480" y="780" width="300" height="70" as="geometry" /></mxCell><mxCell id="c1" value="1. 주행 모드 확인&#10;(키보드 s / q)" style="rhombus;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;" parent="1" vertex="1"><mxGeometry x="880" y="120" width="300" height="100" as="geometry" /></mxCell><mxCell id="c2y" value="2. 주행 연산&#10;vel.x = base_vel - err*k&#10;vel.y = -(base_vel + err*k)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;fillColor=#C6F6D5;strokeColor=#38A169;" parent="1" vertex="1"><mxGeometry x="880" y="280" width="140" height="90" as="geometry" /></mxCell><mxCell id="c2n" value="2. 정지 연산&#10;vel.x = 0&#10;vel.y = 0" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;fillColor=#CBD5E0;strokeColor=#718096;" parent="1" vertex="1"><mxGeometry x="1040" y="280" width="140" height="90" as="geometry" /></mxCell><mxCell id="c3" value="3. 커맨드 퍼블리시&#10;(topic_dxlpub)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="880" y="430" width="300" height="70" as="geometry" /></mxCell><mxCell id="c4" value="4. 디버그 시각화&#10;(Raw / Binary imshow)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="880" y="530" width="300" height="70" as="geometry" /></mxCell><mxCell id="c5" value="5. 처리 성능 측정 및 로깅" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#1A202C;fillColor=#FFFFFF;strokeColor=#A0AEC0;strokeWidth=2;shadow=1;spacing=10;" parent="1" vertex="1"><mxGeometry x="880" y="630" width="300" height="70" as="